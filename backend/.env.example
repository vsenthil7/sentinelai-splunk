# Copy to backend/.env and adjust. All vars are prefixed SENTINEL_.

# --- Core ---
SENTINEL_ENVIRONMENT=dev

# --- Auth (MUST set a strong secret in prod) ---
SENTINEL_JWT_SECRET=change-me-in-prod
SENTINEL_JWT_EXPIRE_MINUTES=60

# --- Database ---
# Dev (SQLite):
SENTINEL_DATABASE_URL=sqlite+aiosqlite:///./sentinel.db
SENTINEL_DB_CREATE_ALL=true
# Prod (Postgres) — set DB_CREATE_ALL=false and run `alembic upgrade head`:
# SENTINEL_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/sentinel
# SENTINEL_DB_CREATE_ALL=false

# --- Splunk (mock for offline; live to wire a real instance) ---
SENTINEL_SPLUNK_BACKEND=mock
SENTINEL_SPLUNK_HOST=https://localhost:8089
SENTINEL_SPLUNK_TOKEN=
SENTINEL_SPLUNK_MCP_URL=

# --- Hosted model ---
SENTINEL_AI_BACKEND=mock
SENTINEL_AI_MODEL=Foundation-Sec-1.1-8B-Instruct

# --- Operations ---
SENTINEL_RATE_LIMIT_PER_MINUTE=120
SENTINEL_CORS_ORIGINS=*
SENTINEL_LOG_JSON=true

# --- Notifications ---
SENTINEL_NOTIFY_WEBHOOK_URL=
SENTINEL_NOTIFY_HIGH_RISK_THRESHOLD=80
